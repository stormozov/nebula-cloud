    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "sass": "^1.94.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "npm:rolldown-vite@7.2.2",
    "vite-bundle-analyzer": "^1.3.2",
