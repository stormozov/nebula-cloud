    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.9.6",
    "redux-persist": "^6.0.0",
    "use-debounce": "^10.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
