    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "checkDeps": "yarn run depcheck",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
